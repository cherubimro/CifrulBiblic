      \field{series}{IEEE International Symposium on Technology and Society}
      \field{title}{Demystifying the Number of the Beast in the Book of Revelation: Examples of Ancient Cryptology and the Interpretation of the ``666{''} Conundrum}
      \field{type}{Proceedings Paper}
      \field{year}{2010}
      \true{nocite}
      \field{pages}{23\bibrangedash 41}
